---
import { parseInventory } from '../../lib/inventory';
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  const items = parseInventory();
  return Array.from(items.values()).map(item => ({
    params: { ref: item.code },
    props: { item },
  }));
}

const { item } = Astro.props;
---

<BaseLayout
  title={`${item.item} (${item.code}) - jeansy.org`}
  description="Relocation item reference page."
>
  <div class="max-w-3xl mx-auto py-8">
    <div class="border rounded-lg p-8" style="border-color: var(--border-color); background-color: var(--bg-card);">

      <h1 class="text-2xl font-bold mb-2" style="color: var(--text-primary);">Relocation Item Reference</h1>
      <p class="text-sm mb-8" style="color: var(--text-muted);">This QR code is attached to an item that is part of a household relocation.</p>

      <div class="mb-6 pb-6 border-b" style="border-color: var(--border-color);">
        <p class="text-xs uppercase tracking-widest mb-1" style="color: var(--text-muted);">Reference</p>
        <p class="text-3xl font-bold font-mono" style="color: var(--text-primary);">{item.code}</p>
      </div>

      <div class="mb-6 pb-6 border-b" style="border-color: var(--border-color);">
        <p class="text-xs uppercase tracking-widest mb-1" style="color: var(--text-muted);">Item</p>
        <p class="text-xl font-semibold" style="color: var(--text-primary);">{item.item}</p>
        {item.seq && <p class="text-sm mt-1" style="color: var(--text-secondary);">{item.seq}</p>}
        {item.room && <p class="text-sm mt-1" style="color: var(--text-muted);">{item.room}</p>}
      </div>

      {(item.fragile || item.note) && (
        <div class="mb-6 pb-6 border-b" style="border-color: var(--border-color);">
          {item.fragile && (
            <p class="text-sm font-semibold mb-1" style="color: var(--text-primary);">Fragile — handle with care</p>
          )}
          {item.note && (
            <p class="text-sm" style="color: var(--text-secondary);">{item.note}</p>
          )}
        </div>
      )}

      <div class="grid gap-6 mb-8" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
        <div>
          <p class="text-xs uppercase tracking-widest mb-1" style="color: var(--text-muted);">Owner</p>
          <p style="color: var(--text-primary);">Richard Jeans</p>
          <a href="mailto:rich@jeansy.org" style="color: var(--link-color);" class="hover:underline text-sm">rich@jeansy.org</a>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest mb-1" style="color: var(--text-muted);">Moving Company</p>
          <p style="color: var(--text-primary);">GB Liners</p>
          <p class="text-sm" style="color: var(--text-secondary);">Ref: LO51399-1</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest mb-1" style="color: var(--text-muted);">From</p>
          <p style="color: var(--text-primary);">Hellerup, Denmark</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest mb-1" style="color: var(--text-muted);">Destination</p>
          <p style="color: var(--text-primary);">Kingston upon Thames, UK</p>
        </div>
      </div>

      <p class="text-sm" style="color: var(--text-muted);">
        If you have found this item or need to get in touch regarding this shipment, please contact
        <a href="mailto:rich@jeansy.org" style="color: var(--link-color);" class="hover:underline">rich@jeansy.org</a>.
      </p>

    </div>
  </div>
</BaseLayout>
